---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProfileHeader from "../components/home/ProfileHeader.astro";
import SectionBlock from "../components/home/SectionBlock.astro";
import { profile, openSource, products, resources } from "../data/site";
---

<BaseLayout title={profile.name} description={profile.tagline}>
  <main class="mx-auto max-w-xl border-b border-[var(--color-border)] px-6 py-16">
    <ProfileHeader />
    <SectionBlock title="Open Source" items={openSource} />
    <SectionBlock title="Products" items={products} />
    <SectionBlock title="Resources" items={resources} />
  </main>
</BaseLayout>
