---
interface Props {
  prompt?: string;
}

const { prompt } = Astro.props;

const chatGptUrl = prompt
  ? `https://chatgpt.com/?q=${encodeURIComponent(prompt)}`
  : undefined;
---

<div class="not-prose flex items-start gap-3">
  <span
    class="mt-1 shrink-0 font-mono text-xs text-(--color-muted)"
    aria-hidden="true"
  >
    ?
  </span>
  <div class="min-w-0 flex-1 font-serif text-base leading-relaxed text-(--color-prose) [&_p]:m-0">
    <slot />
  </div>
  {
    chatGptUrl && (
      <a
        href={chatGptUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="link-subtle shrink-0 self-start font-mono text-xs leading-relaxed text-(--color-muted) mt-1 ml-2"
      >
        Ask AI ↗
      </a>
    )
  }
</div>
