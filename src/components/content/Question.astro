---
interface Props {
  prompt?: string;
}

const { prompt } = Astro.props;

const chatGptUrl = prompt
  ? `https://chatgpt.com/?q=${encodeURIComponent(prompt)}`
  : undefined;

const hasAnswer = Astro.slots.has("answer");
---

<div>
  <div class="flex items-start gap-3">
    <span
      class="not-prose mt-1 shrink-0 font-mono text-xs text-(--color-muted)"
      aria-hidden="true"
    >
      ?
    </span>
    <div class="min-w-0 flex-1">
      <div class="not-prose min-w-0 font-serif text-base leading-relaxed text-(--color-prose) [&_p]:m-0">
        <slot />
      </div>
      {
        chatGptUrl && (
          <a
            href={chatGptUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="not-prose link-subtle mt-2 inline-block font-mono text-xs leading-relaxed text-(--color-muted)"
          >
            Ask AI ↗
          </a>
        )
      }
      {
        hasAnswer && (
          <details class="mt-3">
            <summary class="not-prose cursor-pointer font-sans text-sm text-(--color-muted) hover:text-(--color-text)">
              Show answer
            </summary>
            <div class="mt-3 rounded-md border border-(--color-border) bg-(--color-surface) px-4 py-3">
              <div class="prose prose-lesson max-w-none text-sm">
                <slot name="answer" />
              </div>
            </div>
          </details>
        )
      }
    </div>
  </div>
</div>
