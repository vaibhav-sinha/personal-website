---
interface Props {
  href: string;
  title: string;
  description: string;
  type?: "paper" | "video" | "docs" | "article" | "book";
}

const { href, title, description, type = "article" } = Astro.props;

const typeLabels: Record<NonNullable<Props["type"]>, string> = {
  paper: "Paper",
  video: "Video",
  docs: "Docs",
  article: "Article",
  book: "Book",
};
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="not-prose my-8 flex gap-4 rounded border border-neutral-200 bg-white px-4 py-3 transition-colors hover:border-neutral-300 hover:bg-neutral-50"
>
  <div class="min-w-0 flex-1">
    <p class="font-sans text-xs font-medium uppercase tracking-widest text-neutral-500">
      {typeLabels[type]}
    </p>
    <p class="mt-1 font-sans text-sm font-medium text-neutral-900">{title}</p>
    <p class="mt-1 font-serif text-sm leading-relaxed text-neutral-600">{description}</p>
  </div>
  <span class="shrink-0 self-center text-neutral-400" aria-hidden="true">↗</span>
</a>
