---
interface Props {
  environment: string;
  objective: string;
  actions: string | readonly string[];
  title?: string;
}

const { environment, objective, actions, title = "Problem definition" } = Astro.props;

const actionItems = typeof actions === "string" ? null : actions;
---

<aside
  class="not-prose my-8 rounded-md border border-(--color-accent-dim) bg-(--color-surface-raised) px-5 py-4"
>
  <p class="mb-4 font-mono text-xs uppercase tracking-widest text-(--color-accent)">
    {title}
  </p>
  <dl class="space-y-3">
    <div>
      <dt class="font-mono text-xs text-(--color-muted)">Environment</dt>
      <dd class="mt-0.5 font-serif text-base leading-relaxed text-(--color-prose)">
        {environment}
      </dd>
    </div>
    <div>
      <dt class="font-mono text-xs text-(--color-muted)">Objective</dt>
      <dd class="mt-0.5 font-serif text-base leading-relaxed text-(--color-prose)">
        {objective}
      </dd>
    </div>
    <div>
      <dt class="font-mono text-xs text-(--color-muted)">Actions</dt>
      <dd class="mt-0.5 font-serif text-base leading-relaxed text-(--color-prose)">
        {
          actionItems ? (
            <ul class="mt-1 list-inside list-disc space-y-0.5">
              {actionItems.map((action) => (
                <li>{action}</li>
              ))}
            </ul>
          ) : (
            actions
          )
        }
      </dd>
    </div>
  </dl>
</aside>
