---
interface Props {
  title?: string;
  answer?: string;
}

const { title = "Think about it", answer } = Astro.props;
---

<aside class="not-prose my-8 border-l-2 border-neutral-400 bg-neutral-50 px-5 py-4">
  <p class="mb-2 font-sans text-xs font-medium uppercase tracking-widest text-neutral-500">
    {title}
  </p>
  <div class="font-serif text-base leading-relaxed text-neutral-800">
    <slot />
  </div>
  {
    answer && (
      <details class="mt-4">
        <summary class="cursor-pointer font-sans text-sm text-neutral-600 hover:text-neutral-900">
          Show a possible answer
        </summary>
        <p class="mt-2 font-serif text-sm leading-relaxed text-neutral-700">{answer}</p>
      </details>
    )
  }
</aside>
