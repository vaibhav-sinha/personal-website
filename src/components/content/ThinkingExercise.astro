---
interface Props {
  title?: string;
  answer?: string;
  prompt?: string;
}

const { title = "Think about it", answer, prompt } = Astro.props;

const chatGptUrl = prompt
  ? `https://chatgpt.com/?q=${encodeURIComponent(prompt)}`
  : undefined;
---

<aside class="not-prose my-8 border-l-2 border-(--color-accent-dim) bg-(--color-surface) px-5 py-4">
  <div class="mb-2 flex items-center justify-between gap-3">
    <p class="font-mono text-xs uppercase tracking-widest text-(--color-muted)">
      {title}
    </p>
    {
      chatGptUrl && (
        <a
          href={chatGptUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="link-subtle shrink-0 font-mono text-xs leading-relaxed text-(--color-muted)"
        >
          Ask AI ↗
        </a>
      )
    }
  </div>
  <div class="font-serif text-base leading-relaxed text-(--color-prose)">
    <slot />
  </div>
  {
    answer && (
      <details class="mt-4">
        <summary class="cursor-pointer font-sans text-sm text-(--color-muted) hover:text-(--color-text)">
          Show a possible answer
        </summary>
        <p class="mt-2 font-serif text-sm leading-relaxed text-(--color-prose)">{answer}</p>
      </details>
    )
  }
</aside>
