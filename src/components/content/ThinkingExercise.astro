---
interface Props {
  title?: string;
  answer?: string;
}

const { title = "Think about it", answer } = Astro.props;
---

<aside class="not-prose my-8 border-l-2 border-[var(--color-accent-dim)] bg-[var(--color-surface)] px-5 py-4">
  <p class="mb-2 font-mono text-xs uppercase tracking-widest text-[var(--color-muted)]">
    {title}
  </p>
  <div class="font-serif text-base leading-relaxed text-[var(--color-prose)]">
    <slot />
  </div>
  {
    answer && (
      <details class="mt-4">
        <summary class="cursor-pointer font-sans text-sm text-[var(--color-muted)] hover:text-[var(--color-text)]">
          Show a possible answer
        </summary>
        <p class="mt-2 font-serif text-sm leading-relaxed text-[var(--color-prose)]">{answer}</p>
      </details>
    )
  }
</aside>
