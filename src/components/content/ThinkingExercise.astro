---
interface Props {
  title?: string;
  answer?: string;
  prompt?: string;
}

const { title = "Think about it", answer, prompt } = Astro.props;

const hasAnswerSlot = Astro.slots.has("answer");
const hasAnswer = Boolean(answer) || hasAnswerSlot;

const chatGptUrl = prompt
  ? `https://chatgpt.com/?q=${encodeURIComponent(prompt)}`
  : undefined;
---

<aside class="my-8 border-l-2 border-(--color-accent-dim) bg-(--color-surface) px-5 py-4">
  <div class="not-prose mb-2 flex items-center justify-between gap-3">
    <p class="font-mono text-xs uppercase tracking-widest text-(--color-muted)">
      {title}
    </p>
    {
      chatGptUrl && (
        <a
          href={chatGptUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="link-subtle shrink-0 font-mono text-xs leading-relaxed text-(--color-muted)"
        >
          Ask AI ↗
        </a>
      )
    }
  </div>
  <div class="not-prose font-serif text-base leading-relaxed text-(--color-prose)">
    <slot />
  </div>
  {
    hasAnswer && (
      <details class="mt-4">
        <summary class="not-prose cursor-pointer font-sans text-sm text-(--color-muted) hover:text-(--color-text)">
          Show a possible answer
        </summary>
        {
          hasAnswerSlot ? (
            <div class="mt-2 rounded-md border border-(--color-border) bg-(--color-surface) px-4 py-3">
              <div class="prose prose-lesson max-w-none text-sm">
                <slot name="answer" />
              </div>
            </div>
          ) : (
            <p class="mt-2 font-serif text-sm leading-relaxed text-(--color-prose)">{answer}</p>
          )
        }
      </details>
    )
  }
</aside>
