---
import { Code } from "astro:components";
import type { ComponentProps } from "astro/types";

type CodeLang = NonNullable<ComponentProps<typeof Code>["lang"]>;

interface Props {
  code: string;
  lang?: CodeLang;
  title?: string;
  showLineNumbers?: boolean;
}

const { code, lang = "python", title, showLineNumbers = false } = Astro.props;
---

<figure class="not-prose my-8 overflow-hidden rounded-md border border-(--color-border) bg-(--color-code-bg)">
  {title && (
    <figcaption class="border-b border-(--color-border) bg-(--color-surface) px-4 py-2 font-mono text-xs text-(--color-muted)">
      {title}
    </figcaption>
  )}
  <div class="overflow-x-auto">
    <Code
      code={code.trim()}
      lang={lang}
      theme="github-dark"
      class="m-0 p-4 font-mono text-sm leading-relaxed"
    />
  </div>
</figure>
