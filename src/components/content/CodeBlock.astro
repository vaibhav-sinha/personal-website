---
import { Code } from "astro:components";
import type { ComponentProps } from "astro/types";

type CodeLang = NonNullable<ComponentProps<typeof Code>["lang"]>;

interface Props {
  code: string;
  lang?: CodeLang;
  title?: string;
  showLineNumbers?: boolean;
}

const { code, lang = "python", title, showLineNumbers = false } = Astro.props;
---

<figure class="not-prose my-8 overflow-hidden rounded border border-neutral-200 bg-white">
  {title && (
    <figcaption class="border-b border-neutral-200 bg-neutral-50 px-4 py-2 font-mono text-xs text-neutral-500">
      {title}
    </figcaption>
  )}
  <div class="overflow-x-auto">
    <Code
      code={code.trim()}
      lang={lang}
      theme="github-light"
      class="m-0 p-4 font-mono text-sm leading-relaxed"
    />
  </div>
</figure>
