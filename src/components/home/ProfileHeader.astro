---
import { profile, socialLinks } from "../../data/site";
---

<header class="mb-12">
  <div class="mb-8 flex items-start gap-5">
    <img
      src={profile.photo}
      alt={`${profile.name} profile photo`}
      width="56"
      height="56"
      class="size-14 shrink-0 rounded-md border border-[var(--color-border)] bg-[var(--color-surface-raised)] object-cover"
    />
    <div>
      <h1 class="text-[1.375rem] font-semibold tracking-tight text-[var(--color-text-bright)]">
        {profile.name}
      </h1>
      <p class="mt-1 font-mono text-[0.8125rem] text-[var(--color-muted)]">{profile.tagline}</p>
    </div>
  </div>
  <nav class="flex gap-5" aria-label="Social links">
    {
      socialLinks.map((link) => (
        <a
          href={link.href}
          class="font-mono text-[0.8125rem] text-[var(--color-muted)] link-subtle"
          target="_blank"
          rel="noopener noreferrer"
        >
          {link.label}
        </a>
      ))
    }
  </nav>
</header>
