---
import {
  getNavItemHref,
  isNavItemActive,
  rlCourseNav,
} from "../../data/rl-course-nav";

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;

function parentLinkClass(isActive: boolean, isParentActive: boolean, hasChildren: boolean) {
  const classes = ["nav-link"];
  if (isActive) classes.push("nav-link-active");
  else if (hasChildren && isParentActive) classes.push("nav-link-parent-active");
  return classes;
}
---

<aside class="hidden min-h-full w-(--sidebar-width) shrink-0 border-r border-(--color-border) lg:block">
  <nav class="sticky top-0 max-h-screen overflow-y-auto px-6 py-8" aria-label="Course navigation">
    {
      rlCourseNav.map((group) => (
        <div class="mb-8 last:mb-0">
          <p class="nav-section-label mb-3">{group.section}</p>
          <ul>
            {group.items.map((item) => {
              const isParentActive = isNavItemActive(item, currentSlug);
              const isCurrentPage = currentSlug === item.slug;
              const hasChildren = item.children && item.children.length > 0;

              return (
                <li>
                  <a
                    href={getNavItemHref(item.slug)}
                    class:list={parentLinkClass(isCurrentPage, isParentActive, !!hasChildren)}
                    aria-current={isCurrentPage ? "page" : undefined}
                  >
                    {item.title}
                  </a>
                  {hasChildren && (
                    <ul class="nav-children">
                      {item.children!.map((child) => {
                        const isChildActive = currentSlug === child.slug;
                        return (
                          <li>
                            <a
                              href={getNavItemHref(child.slug)}
                              class:list={["nav-link", isChildActive && "nav-link-active"]}
                              aria-current={isChildActive ? "page" : undefined}
                            >
                              {child.title}
                            </a>
                          </li>
                        );
                      })}
                    </ul>
                  )}
                </li>
              );
            })}
          </ul>
        </div>
      ))
    }
  </nav>
</aside>

<details class="border-b border-(--color-border) bg-(--color-surface) lg:hidden">
  <summary class="cursor-pointer px-6 py-4 font-mono text-sm text-(--color-text)">
    Course contents
  </summary>
  <nav class="border-t border-(--color-border) px-6 py-4" aria-label="Course navigation">
    {
      rlCourseNav.map((group) => (
        <div class="mb-6 last:mb-0">
          <p class="nav-section-label mb-2">{group.section}</p>
          <ul>
            {group.items.map((item) => {
              const isParentActive = isNavItemActive(item, currentSlug);
              const isCurrentPage = currentSlug === item.slug;
              const hasChildren = item.children && item.children.length > 0;

              return (
                <li>
                  <a
                    href={getNavItemHref(item.slug)}
                    class:list={parentLinkClass(isCurrentPage, isParentActive, !!hasChildren)}
                  >
                    {item.title}
                  </a>
                  {hasChildren && (
                    <ul class="nav-children">
                      {item.children!.map((child) => {
                        const isChildActive = currentSlug === child.slug;
                        return (
                          <li>
                            <a
                              href={getNavItemHref(child.slug)}
                              class:list={["nav-link", isChildActive && "nav-link-active"]}
                            >
                              {child.title}
                            </a>
                          </li>
                        );
                      })}
                    </ul>
                  )}
                </li>
              );
            })}
          </ul>
        </div>
      ))
    }
  </nav>
</details>
