---
import type { RlCourseLesson } from "../../lib/course";

interface Props {
  prev: RlCourseLesson | null;
  next: RlCourseLesson | null;
}

const { prev, next } = Astro.props;

const cardClass =
  "group flex max-w-[45%] flex-col gap-1 rounded border border-(--color-border) bg-(--color-surface) px-4 py-3 transition-colors hover:border-(--color-muted)";
---

{
  (prev || next) && (
    <nav
      class="not-prose mt-16 flex items-stretch justify-between gap-4 border-t border-(--color-border) pt-8"
      aria-label="Lesson navigation"
    >
      {prev ? (
        <a href={`/rl-course/${prev.id}`} class:list={[cardClass]}>
          <span class="font-mono text-xs uppercase tracking-widest text-(--color-muted)">Previous</span>
          <span class="font-sans text-sm font-medium text-(--color-text) group-hover:text-(--color-accent)">
            {prev.data.title}
          </span>
        </a>
      ) : (
        <div />
      )}

      {next ? (
        <a href={`/rl-course/${next.id}`} class:list={[cardClass, "items-end text-right"]}>
          <span class="font-mono text-xs uppercase tracking-widest text-(--color-muted)">Next</span>
          <span class="font-sans text-sm font-medium text-(--color-text) group-hover:text-(--color-accent)">
            {next.data.title}
          </span>
        </a>
      ) : (
        <div />
      )}
    </nav>
  )
}
