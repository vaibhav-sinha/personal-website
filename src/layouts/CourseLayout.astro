---
import BaseLayout from "./BaseLayout.astro";
import CourseSidebar from "../components/course/CourseSidebar.astro";
import PrevNext from "../components/course/PrevNext.astro";
import { courseMeta } from "../data/rl-course-nav";
import type { RlCourseLesson } from "../lib/course";

interface Props {
  title: string;
  description?: string;
  currentSlug?: string;
  prev?: RlCourseLesson | null;
  next?: RlCourseLesson | null;
}

const { title, description, currentSlug, prev = null, next = null } = Astro.props;
---

<BaseLayout title={`${title} · ${courseMeta.title}`} description={description}>
  <div class="flex min-h-screen flex-col">
    <header class="border-b border-(--color-border) bg-(--color-surface)">
      <div class="mx-auto flex max-w-6xl items-center gap-4 px-6 py-4">
        <a href="/" class="font-mono text-sm text-(--color-muted) link-subtle">Home</a>
        <span class="text-(--color-muted)" aria-hidden="true">/</span>
        <a href="/rl-course" class="font-mono text-sm text-(--color-text) link-subtle">{courseMeta.title}</a>
      </div>
    </header>

    <div class="mx-auto flex w-full max-w-6xl flex-1">
      <CourseSidebar currentSlug={currentSlug} />

      <main class="min-w-0 flex-1 px-6 py-10 lg:px-10">
        <article class="mx-auto max-w-(--content-max)">
          <header class="mb-10 border-b border-(--color-border) pb-8">
            <h1 class="font-sans text-3xl font-semibold tracking-tight text-(--color-text-bright)">
              {title}
            </h1>
            {description && (
              <p class="mt-3 font-serif text-lg leading-relaxed text-(--color-muted)">
                {description}
              </p>
            )}
          </header>

          <div class="prose prose-lesson">
            <slot />
          </div>

          {currentSlug && <PrevNext prev={prev} next={next} />}
        </article>
      </main>
    </div>
  </div>
</BaseLayout>
